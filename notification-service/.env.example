# Copy to .env — never commit .env

# --- Email (Mailtrap SMTP) ---
EMAIL_ENABLED=true
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password
SMTP_FROM_EMAIL=Foody <mail@foody.local>
SMTP_STARTTLS=true
SMTP_USE_SSL=false

# --- SMS (Twilio) — set SMS_ENABLED=true when configured ---
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Push (FCM) — set PUSH_ENABLED=true when configured ---
PUSH_ENABLED=false
FCM_SERVER_KEY=

AUTH_SERVICE_URL=http://auth-service:5000
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=notification-service
